{{- if eq .chezmoi.os "darwin" }}
#!/bin/bash
set -euo pipefail

if ! command -v bw &> /dev/null; then
    echo "Installing Bitwarden CLI via Homebrew..."
    
    if ! command -v brew &> /dev/null; then
        echo "Homebrew not found. Installing..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi
    
    brew install bitwarden-cli
fi

if ! brew list --cask bitwarden &> /dev/null; then
    echo "Installing Bitwarden Desktop via Homebrew..."
    brew install --cask bitwarden
fi

{{- else if eq .chezmoi.os "linux" }}
#!/bin/bash
set -euo pipefail

if ! command -v bw &> /dev/null; then
    echo "Installing Bitwarden CLI..."
    
    {{- if or (eq .chezmoi.osRelease.id "arch") (eq .chezmoi.osRelease.idLike "arch") }}
    if command -v yay &> /dev/null; then
        yay -S --noconfirm bitwarden-cli
    elif command -v paru &> /dev/null; then
        paru -S --noconfirm bitwarden-cli
    else
        echo "No AUR helper found, downloading binary..."
        curl -sL "https://vault.bitwarden.com/download/?app=cli&platform=linux" -o /tmp/bw.zip
        unzip -o /tmp/bw.zip -d /tmp
        sudo install -m 755 /tmp/bw /usr/local/bin/bw
        rm /tmp/bw.zip /tmp/bw
    fi

    if ! pacman -Qi bitwarden &> /dev/null; then
        echo "Installing Bitwarden Desktop..."
        if command -v yay &> /dev/null; then
            yay -S --noconfirm bitwarden
        elif command -v paru &> /dev/null; then
            paru -S --noconfirm bitwarden
        else
            echo "No AUR helper found, skipping desktop client installation"
        fi
    fi
    
    {{- else }}
    if command -v flatpak &> /dev/null; then
        echo "Installing via Flatpak..."
        flatpak install -y flathub com.bitwarden.desktop

        echo '#!/bin/bash' | sudo tee /usr/local/bin/bw > /dev/null
        echo 'flatpak run --command=bw com.bitwarden.desktop "$@"' | sudo tee -a /usr/local/bin/bw > /dev/null
        sudo chmod +x /usr/local/bin/bw
        
    elif command -v snap &> /dev/null; then
        echo "Installing via Snap..."
        sudo snap install bw
        
    else
        echo "No Flatpak or Snap found, downloading binary..."
        curl -sL "https://vault.bitwarden.com/download/?app=cli&platform=linux" -o /tmp/bw.zip
        unzip -o /tmp/bw.zip -d /tmp
        sudo install -m 755 /tmp/bw /usr/local/bin/bw
        rm /tmp/bw.zip /tmp/bw
    fi
    {{- end }}
fi

{{- end }}

if command -v bw &> /dev/null; then
    echo "Configuring Bitwarden CLI for Vaultwarden..."
    bw config server https://vw.ceereals.space
fi
