binds {

    // ────────────── Keybindings ──────────────
    // https://github.com/YaLTeR/niri/wiki/Configuration:-Key-Bindings

    // ─── Hotkey overlay (built-in cheatsheet, niri-native) ───
    MOD+SHIFT+ESCAPE                     { show-hotkey-overlay; }

    // ─── Applications ───
    MOD+RETURN                          hotkey-overlay-title="Open Terminal: Ghostty"            { spawn "ghostty"; }
    MOD+SPACE                           hotkey-overlay-title="Open App Launcher: DMS Spotlight"   { spawn-sh "dms ipc call spotlight toggle"; }
    MOD+B                               hotkey-overlay-title="Open Browser: Firefox"              { spawn "firefox"; }
    MOD+E                               hotkey-overlay-title="File Manager: Nautilus"             { spawn "nautilus"; }

    // ─── Audio Controls (DMS audio IPC, with OSD) ───
    XF86AudioRaiseVolume                allow-when-locked=true { spawn-sh "dms ipc call audio increment 5"; }
    XF86AudioLowerVolume                allow-when-locked=true { spawn-sh "dms ipc call audio decrement 5"; }
    XF86AudioMute                       allow-when-locked=true { spawn-sh "dms ipc call audio mute"; }
    XF86AudioMicMute                    allow-when-locked=true { spawn-sh "dms ipc call audio micmute"; }

    // ─── Brightness Controls (DMS OSD) ───
    XF86MonBrightnessUp                 allow-when-locked=true { spawn-sh "dms ipc call brightness increment 5 \"\""; }
    XF86MonBrightnessDown               allow-when-locked=true { spawn-sh "dms ipc call brightness decrement 5 \"\""; }

    // ─── Media Controls (DMS MPRIS) ───
    XF86AudioPlay                       allow-when-locked=true { spawn-sh "dms ipc call mpris playPause"; }
    XF86AudioNext                       allow-when-locked=true { spawn-sh "dms ipc call mpris next"; }
    XF86AudioPrev                       allow-when-locked=true { spawn-sh "dms ipc call mpris previous"; }

    // ─── Universal Copy/Paste/Cut (context-aware via niri msg + wtype) ───
    // Terminals: Ctrl+Shift+{C,V}; everything else: Ctrl+{C,V,X}. Cut no-op in terminals.
    MOD+C                               hotkey-overlay-title="Universal copy"  { spawn-sh "~/.config/niri/scripts/universal-clipboard.sh copy"; }
    MOD+V                               hotkey-overlay-title="Universal paste" { spawn-sh "~/.config/niri/scripts/universal-clipboard.sh paste"; }
    MOD+X                               hotkey-overlay-title="Universal cut"   { spawn-sh "~/.config/niri/scripts/universal-clipboard.sh cut"; }

    // ─── DMS panels & menus ───
    MOD+SHIFT+L                         hotkey-overlay-title="Lock screen (DMS)"                 { spawn-sh "dms ipc call lock lock"; }
    MOD+D                               hotkey-overlay-title="Notifications history"             { spawn-sh "dms ipc call notifications toggle"; }
    MOD+N                               hotkey-overlay-title="Control center"                    { spawn-sh "dms ipc call control-center toggle"; }
    MOD+SHIFT+W                         hotkey-overlay-title="Wallpaper selector"                { spawn-sh "dms ipc call dankdash wallpaper"; }
    MOD+PERIOD                          hotkey-overlay-title="Emoji picker"                      { spawn-sh "dms ipc call spotlight openQuery emoji:"; }
    MOD+CTRL+V                          hotkey-overlay-title="Clipboard history"                 { spawn-sh "dms ipc call clipboard toggle"; }
    MOD+SHIFT+B                         hotkey-overlay-title="Toggle DMS bar"                    { spawn-sh "dms ipc call bar toggle"; }
    MOD+ESCAPE                          hotkey-overlay-title="Session menu (logout/reboot)"      { spawn-sh "dms ipc call powermenu toggle"; }

    // ─── Window Close (Omarchy: MOD+W) ───
    MOD+W                               hotkey-overlay-title="Close current window" { close-window; }

    // ─── Window Focus (vim-style hjk + arrows; MOD+L is reserved for SHIFT+L lock) ───
    MOD+LEFT                            { focus-column-left; }
    MOD+H                               { focus-column-left; }
    MOD+RIGHT                           { focus-column-right; }
    // (MOD+L intentionally NOT bound: would conflict with the MOD+SHIFT+L lock chord ergonomics)
    MOD+UP                              { focus-window-up; }
    MOD+K                               { focus-window-up; }
    MOD+DOWN                            { focus-window-down; }
    MOD+J                               { focus-window-down; }

    // ─── Window Movement ───
    MOD+CTRL+LEFT                       { move-column-left; }
    MOD+CTRL+H                          { move-column-left; }
    MOD+CTRL+RIGHT                      { move-column-right; }
    MOD+CTRL+UP                         { move-window-up; }
    MOD+CTRL+K                          { move-window-up; }
    MOD+CTRL+DOWN                       { move-window-down; }
    MOD+CTRL+J                          { move-window-down; }

    MOD+HOME                            { focus-column-first; }
    MOD+END                             { focus-column-last; }
    MOD+CTRL+HOME                       { move-column-to-first; }
    MOD+CTRL+END                        { move-column-to-last; }

    // ─── Multi-monitor focus and movement ───
    MOD+SHIFT+LEFT                      { focus-monitor-left; }
    MOD+SHIFT+RIGHT                     { focus-monitor-right; }
    MOD+SHIFT+UP                        { focus-monitor-up; }
    MOD+SHIFT+DOWN                      { focus-monitor-down; }

    MOD+SHIFT+CTRL+LEFT                 { move-column-to-monitor-left; }
    MOD+SHIFT+CTRL+RIGHT                { move-column-to-monitor-right; }
    MOD+SHIFT+CTRL+UP                   { move-column-to-monitor-up; }
    MOD+SHIFT+CTRL+DOWN                 { move-column-to-monitor-down; }

    // ─── Workspace Switching ───
    MOD+WHEELSCROLLDOWN                 cooldown-ms=150 { focus-workspace-down; }
    MOD+WHEELSCROLLUP                   cooldown-ms=150 { focus-workspace-up; }
    MOD+CTRL+WHEELSCROLLDOWN            cooldown-ms=150 { move-column-to-workspace-down; }
    MOD+CTRL+WHEELSCROLLUP              cooldown-ms=150 { move-column-to-workspace-up; }

    MOD+WHEELSCROLLRIGHT                { focus-column-right; }
    MOD+WHEELSCROLLLEFT                 { focus-column-left; }
    MOD+CTRL+WHEELSCROLLRIGHT           { move-column-right; }
    MOD+CTRL+WHEELSCROLLLEFT            { move-column-left; }

    MOD+SHIFT+WHEELSCROLLDOWN           { focus-column-right; }
    MOD+SHIFT+WHEELSCROLLUP             { focus-column-left; }
    MOD+CTRL+SHIFT+WHEELSCROLLDOWN      { move-column-right; }
    MOD+CTRL+SHIFT+WHEELSCROLLUP        { move-column-left; }

    MOD+1                               { focus-workspace 1; }
    MOD+2                               { focus-workspace 2; }
    MOD+3                               { focus-workspace 3; }
    MOD+4                               { focus-workspace 4; }
    MOD+5                               { focus-workspace 5; }
    MOD+6                               { focus-workspace 6; }
    MOD+7                               { focus-workspace 7; }
    MOD+8                               { focus-workspace 8; }
    MOD+9                               { focus-workspace 9; }

    MOD+CTRL+1                          { move-column-to-workspace 1; }
    MOD+CTRL+2                          { move-column-to-workspace 2; }
    MOD+CTRL+3                          { move-column-to-workspace 3; }
    MOD+CTRL+4                          { move-column-to-workspace 4; }
    MOD+CTRL+5                          { move-column-to-workspace 5; }
    MOD+CTRL+6                          { move-column-to-workspace 6; }
    MOD+CTRL+7                          { move-column-to-workspace 7; }
    MOD+CTRL+8                          { move-column-to-workspace 8; }
    MOD+CTRL+9                          { move-column-to-workspace 9; }

    MOD+TAB                             { focus-workspace-previous; }

    // ─── Layout Controls (MOD+C reassigned to Universal copy; center on MOD+SHIFT+C) ───
    MOD+CTRL+F                          { expand-column-to-available-width; }
    MOD+SHIFT+C                         { center-column; }
    MOD+CTRL+SHIFT+C                    { center-visible-columns; }
    MOD+MINUS                           { set-column-width "-10%"; }
    MOD+EQUAL                           { set-column-width "+10%"; }
    MOD+SHIFT+MINUS                     { set-window-height "-10%"; }
    MOD+SHIFT+EQUAL                     { set-window-height "+10%"; }

    // ─── Modes ───
    MOD+T                               hotkey-overlay-title="Toggle window floating"            { toggle-window-floating; }
    MOD+F                               hotkey-overlay-title="Fullscreen window"                 { fullscreen-window; }
    MOD+SHIFT+T                         hotkey-overlay-title="Toggle column tabbed display"      { toggle-column-tabbed-display; }

    // ─── Screenshots (niri-built-in) ───
    CTRL+SHIFT+1                        { screenshot; }
    CTRL+SHIFT+2                        { screenshot-screen; }
    CTRL+SHIFT+3                        { screenshot-window; }

    // ─── Emergency Escape (disable shortcut inhibitor on stuck fullscreen apps) ───
    // Moved off MOD+ESC because that's now the session menu. 4-key chord by design:
    // unlikely to be pressed accidentally, still reachable when a game/inhibitor traps your keys.
    MOD+SHIFT+CTRL+ESCAPE               allow-inhibiting=false hotkey-overlay-title="Emergency: disable shortcut inhibitor" { toggle-keyboard-shortcuts-inhibit; }

    // ─── Exit / Power ───
    CTRL+ALT+DELETE                     { quit; }
    MOD+SHIFT+P                         hotkey-overlay-title="Power off monitors"  { power-off-monitors; }
    MOD+O                               repeat=false hotkey-overlay-title="Toggle overview" { toggle-overview; }
}
